{
  "name": "rust-diffforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:macos:stable": "APPLE_SIGNING_IDENTITY=\"Diff Forge AI Local Development\" tauri dev",
    "dev:web": "vite --host 127.0.0.1 --logLevel error",
    "dev:web:verbose": "vite --host 127.0.0.1",
    "build": "tauri build",
    "build:macos:stable": "APPLE_SIGNING_IDENTITY=\"Diff Forge AI Local Development\" tauri build --bundles app",
    "build:web": "vite build",
    "package": "tauri build",
    "package:macos:stable": "APPLE_SIGNING_IDENTITY=\"Diff Forge AI Local Development\" tauri build --bundles app",
    "register:windows:dev-deeplink": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-windows-dev-deeplink.ps1",
    "preview": "vite preview",
    "macos:accessibility:reset": "tccutil reset Accessibility ai.diffforge.desktop",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:macos:stable": "APPLE_SIGNING_IDENTITY=\"Diff Forge AI Local Development\" tauri dev",
    "tauri:dev:existing": "tauri dev --config src-tauri/tauri.dev.conf.json --no-dev-server-wait",
    "tauri:dev:existing:macos:stable": "APPLE_SIGNING_IDENTITY=\"Diff Forge AI Local Development\" tauri dev --config src-tauri/tauri.dev.conf.json --no-dev-server-wait",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "prismjs": "^1.30.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.0",
    "styled-components": "^6.4.1",
    "styled-icons": "^10.47.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0"
  }
}
