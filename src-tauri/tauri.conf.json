{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Diff Forge AI",
  "version": "0.5.1",
  "identifier": "ai.diffforge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Diff Forge AI",
        "width": 1080,
        "height": 720,
        "minWidth": 860,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "acceptFirstMouse": true,
        "backgroundColor": "#000000",
        "backgroundThrottling": "throttle",
        "shadow": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$TEMP/**"
        ]
      },
      "csp": "default-src 'self'; connect-src 'self' blob: ipc: http://ipc.localhost ws://127.0.0.1:* ws://localhost:* https://diffforge.ai https://registry-api.tscircuit.com https://cjs.tscircuit.com https://jscdn.tscircuit.com https://cdn.jsdelivr.net https://unpkg.com https://jlcsearch.tscircuit.com https://easyeda.com https://modules.easyeda.com https://modelcdn.tscircuit.com https://kicad-mod-cache.tscircuit.com; img-src 'self' asset: http://asset.localhost data:; media-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self' blob: 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval'; worker-src 'self' blob:",
      "dangerousDisableAssetCspModification": [
        "style-src",
        "script-src"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Diff Forge AI",
    "homepage": "https://diffforge.ai",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "installer/windows/diffforge-cli-path.nsh",
        "installerIcon": "icons/icon.ico"
      }
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/diffforge": "installer/linux/diffforge"
        },
        "postInstallScript": "installer/linux/postinstall.sh",
        "postRemoveScript": "installer/linux/postremove.sh"
      },
      "rpm": {
        "files": {
          "/usr/bin/diffforge": "installer/linux/diffforge"
        },
        "postInstallScript": "installer/linux/postinstall.sh",
        "postRemoveScript": "installer/linux/postremove.sh"
      }
    },
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "resources": [
      "icons/128x128.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "diffforge"
        ]
      }
    }
  }
}
