[package]
name = "silero_vad_burn"
version = "0.1.1"
edition = "2024"

description = "A Silero_vad inference lib in Rust base on Burn framework"
license = "MIT"
repository = "https://github.com/second-state/silero_vad_burn"
authors = ["csh <458761603@qq.com>"]

[dependencies]
burn = { version = "0.20" }
burn-store = { version = "0.20", features = ["burnpack"] }
thiserror = "2.0.18"

[dev-dependencies]
wav_io = "0.1"
burn-ndarray = { version = "0.20" }

[build-dependencies]
burn-import = "0.20.0"
