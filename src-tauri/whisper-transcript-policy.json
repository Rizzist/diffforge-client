{
  "name": "whisper-local-coding-policy",
  "audio_ms_min_for_speech_ms": 900,
  "capture_rms_min_for_speech": 0.01,
  "capture_peak_min_for_speech": 0.02,
  "suppress_bracketted_markers": true,
  "suppress_bracketted_markers_max_chars": 24,
  "no_speech_markers": [
    "[BLANK_AUDIO]",
    "[BLANK]",
    "[SILENCE]",
    "[NOISE]",
    "[MUSIC]"
  ],
  "low_energy_suppressed_tokens": [
    "you"
  ],
  "low_energy_max_chars": 4,
  "low_energy_max_words": 1
}
